{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "Diamond MCP — Observability",
  "tags": ["diamond", "mcp"],
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "5s",
  "templating": { "list": [] },
  "panels": [
    {
      "type": "row",
      "title": "Tools — Rate / Errors / Duration",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Tool call rate (RPS) by tool",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(mcp_tool_calls_total{application=\"diamond-mcp\"}[1m])) by (tool)",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tool error rate by tool",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(mcp_tool_calls_total{application=\"diamond-mcp\", status=\"error\"}[1m])) by (tool)",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Error ratio (all tools)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(mcp_tool_calls_total{application=\"diamond-mcp\", status=\"error\"}[5m])) / clamp_min(sum(rate(mcp_tool_calls_total{application=\"diamond-mcp\"}[5m])), 1e-9)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tool latency p50 / p95 / p99 (all tools)",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(mcp_tool_latency_seconds_bucket{application=\"diamond-mcp\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(mcp_tool_latency_seconds_bucket{application=\"diamond-mcp\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(mcp_tool_latency_seconds_bucket{application=\"diamond-mcp\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 latency by tool (find the slow tool)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 17 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(mcp_tool_latency_seconds_bucket{application=\"diamond-mcp\"}[5m])) by (le, tool))",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Cache & Upstream",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 }
    },
    {
      "type": "stat",
      "title": "Cache hit ratio",
      "description": "Share of tool fetches served from the in-process TTL cache instead of hitting the API.",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 26 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "green", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(mcp_cache_events_total{application=\"diamond-mcp\", result=\"hit\"}[5m])) / clamp_min(sum(rate(mcp_cache_events_total{application=\"diamond-mcp\"}[5m])), 1e-9)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cache hits vs misses (per second)",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 26 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(mcp_cache_events_total{application=\"diamond-mcp\", result=\"hit\"}[1m]))",
          "legendFormat": "hits",
          "refId": "A"
        },
        {
          "expr": "sum(rate(mcp_cache_events_total{application=\"diamond-mcp\", result=\"miss\"}[1m]))",
          "legendFormat": "misses",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Upstream API requests by status",
      "description": "Calls the MCP server makes to diamond-api. 'circuit_open' = breaker short-circuited the call.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 34 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(mcp_upstream_requests_total{application=\"diamond-mcp\"}[1m])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    }
  ]
}
