{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "Diamond API — Observability",
  "tags": ["diamond"],
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "5s",
  "templating": { "list": [] },
  "panels": [
    {
      "type": "row",
      "title": "Traffic & Latency",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Request rate (RPS) by URI",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"diamond-api\"}[1m])) by (uri)",
          "legendFormat": "{{uri}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error rate (4xx/5xx) by outcome",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"diamond-api\", outcome=~\"CLIENT_ERROR|SERVER_ERROR\"}[1m])) by (outcome)",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99 (all endpoints)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{application=\"diamond-api\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"diamond-api\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"diamond-api\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 latency by URI (find the slow endpoint)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"diamond-api\"}[5m])) by (le, uri))",
          "legendFormat": "{{uri}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Connection Pool & JVM",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 }
    },
    {
      "type": "timeseries",
      "title": "HikariCP connections (active / idle / pending)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"diamond-api\"}",
          "legendFormat": "active",
          "refId": "A"
        },
        {
          "expr": "hikaricp_connections_idle{application=\"diamond-api\"}",
          "legendFormat": "idle",
          "refId": "B"
        },
        {
          "expr": "hikaricp_connections_pending{application=\"diamond-api\"}",
          "legendFormat": "pending",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM heap used & GC pause rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{application=\"diamond-api\", area=\"heap\"})",
          "legendFormat": "heap used",
          "refId": "A"
        },
        {
          "expr": "rate(jvm_gc_pause_seconds_count{application=\"diamond-api\"}[1m])",
          "legendFormat": "gc pauses/s",
          "refId": "B"
        }
      ]
    },
    {
      "type": "row",
      "title": "Cache-fronted service work (the N+1 story)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 }
    },
    {
      "type": "timeseries",
      "title": "Avg latency of cache-MISS service work (@Observed)",
      "description": "On a cache hit the @Cacheable proxy short-circuits the method, so these timers measure real work — the path the N+1 fixes target.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "rate(propboard_board_seconds_sum{application=\"diamond-api\"}[5m]) / rate(propboard_board_seconds_count{application=\"diamond-api\"}[5m])",
          "legendFormat": "propBoard.board",
          "refId": "A"
        },
        {
          "expr": "rate(projections_game_seconds_sum{application=\"diamond-api\"}[5m]) / rate(projections_game_seconds_count{application=\"diamond-api\"}[5m])",
          "legendFormat": "projections.game",
          "refId": "B"
        },
        {
          "expr": "rate(odds_bestPlays_seconds_sum{application=\"diamond-api\"}[5m]) / rate(odds_bestPlays_seconds_count{application=\"diamond-api\"}[5m])",
          "legendFormat": "odds.bestPlays",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cache-miss work rate (how often we do real work)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(propboard_board_seconds_count{application=\"diamond-api\"}[1m]))",
          "legendFormat": "propBoard misses/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(projections_game_seconds_count{application=\"diamond-api\"}[1m]))",
          "legendFormat": "projections misses/s",
          "refId": "B"
        }
      ]
    }
  ]
}
