# Copy to .env and fill in values before running

# PostgreSQL connection string (matches docker-compose defaults)
DATABASE_URL=postgresql://diamond:diamond@localhost:5432/diamond

# Optional: override the MLB Stats API base URL (default: https://statsapi.mlb.com/api/v1)
# MLB_STATS_API=https://statsapi.mlb.com/api/v1

# Optional: The Odds API key (the-odds-api.com) for `refresh-odds`.
# Without it, refresh-odds is a no-op; use `refresh-odds --sample` to load fixtures.
# ODDS_API_KEY=
