<?xml version="1.0" encoding="UTF-8"?>
<!--
  Structured logging. Micrometer Tracing (OTel bridge) puts the active traceId/spanId
  into the SLF4J MDC on every request, so each line can be correlated back to its trace
  in Jaeger.

  - default profile  → JSON lines (LogstashEncoder includes all MDC, incl. traceId/spanId).
  - `local` profile  → human-readable console with the trace ids inline, for dev.
  Activate the readable form with `-Dspring.profiles.active=local`.
-->
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <springProfile name="local">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} %-5level [%X{traceId:-},%X{spanId:-}] %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <springProfile name="!local">
        <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <customFields>{"service":"diamond-api"}</customFields>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="JSON"/>
        </root>
    </springProfile>
</configuration>
