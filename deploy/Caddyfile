# Same-origin routing: the web app and the API share one public origin, so the
# httpOnly session cookie works with SameSite=Lax and CORS is unnecessary.
#   {$DOMAIN}/api/*  → Spring Boot API   (note: /actuator is NOT exposed publicly)
#   {$DOMAIN}/*      → Next.js web app
#
# Caddy auto-provisions/renews TLS via Let's Encrypt for a real domain, or uses its
# internal CA when DOMAIN=localhost (local testing). ACME_EMAIL (from .env) registers
# the ACME account so Let's Encrypt can send cert-expiry notices; harmless if unset.

{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode gzip

	handle /api/* {
		reverse_proxy api:8080
	}

	handle {
		reverse_proxy web:3000
	}
}
