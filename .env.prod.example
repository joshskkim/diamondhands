# Copy to `.env` next to compose.prod.yml on the host and fill in real values.
# `.env` is gitignored — never commit it.

# Public domain Caddy serves (and the origin baked into the web image). Use
# DOMAIN=localhost for local testing (Caddy issues an internal-CA cert).
DOMAIN=example.com

# Email registered with Let's Encrypt (optional) — used only for cert-expiry
# notices. Leave blank to skip ACME account registration.
ACME_EMAIL=

# Postgres password (also used by the API, Flyway, and the ingester). Generate one:
#   openssl rand -base64 24
DB_PASSWORD=change-me

# API session-JWT signing key, >= 32 bytes. Generate one:
#   openssl rand -base64 48
AUTH_JWT_SECRET=change-me-32-bytes-minimum

# Grafana admin password (Grafana is bound to 127.0.0.1; reach it via SSH tunnel).
GRAFANA_ADMIN_PASSWORD=change-me

# The Odds API key (optional — without it, `refresh-odds` is a no-op).
ODDS_API_KEY=

# Gemini (Google Gen AI) API key for the "Ask Diamond" AI query feature. Without it
# the /api/ask endpoint stays disabled (503). Set AI_ENABLED=true to turn it on.
GEMINI_API_KEY=
AI_ENABLED=false
# Optional: override the model (default gemini-2.5-flash; gemini-2.5-pro is more capable).
# AI_MODEL=gemini-2.5-flash

# Image source. Defaults work for CD-pushed images; override to pin a tag.
REGISTRY=ghcr.io/joshskkim
IMAGE_TAG=latest
