# Copy to `.env` next to compose.prod.yml on the host and fill in real values.
# `.env` is gitignored — never commit it.

# Public domain Caddy serves (and the origin baked into the web image). Use
# DOMAIN=localhost for local testing (Caddy issues an internal-CA cert).
DOMAIN=example.com

# Email registered with Let's Encrypt — used for cert-expiry notices. REQUIRED:
# the bundled Caddyfile has an `email {$ACME_EMAIL}` directive that fails to parse
# if this is blank (Caddy crash-loops, port 443 never opens). Set a real address.
ACME_EMAIL=you@example.com

# Postgres password (also used by the API, Flyway, and the ingester). MUST be
# URL-safe: the ingester embeds it in a postgresql:// URL, so a base64 password
# containing `/`, `+`, or `=` corrupts the connection string. Use hex:
#   openssl rand -hex 24
DB_PASSWORD=change-me

# API session-JWT signing key, >= 32 bytes. Generate one:
#   openssl rand -base64 48
AUTH_JWT_SECRET=change-me-32-bytes-minimum

# Grafana admin password (Grafana is bound to 127.0.0.1; reach it via SSH tunnel).
GRAFANA_ADMIN_PASSWORD=change-me

# The Odds API key (optional — without it, `refresh-odds` is a no-op).
ODDS_API_KEY=

# Gemini (Google Gen AI) API key for the "Ask Diamond" AI query feature. Without it
# the /api/ask endpoint stays disabled (503). Set AI_ENABLED=true to turn it on.
GEMINI_API_KEY=
AI_ENABLED=false
# Optional: override the model (default gemini-2.5-flash; gemini-2.5-pro is more capable).
# AI_MODEL=gemini-2.5-flash

# Stripe billing (optional — billing endpoints stay disabled/503 without a secret key).
# Use LIVE keys in prod. The webhook secret is the signing secret of the dashboard
# webhook endpoint pointed at https://DOMAIN/api/billing/webhook. The price ids are the
# Stripe Price objects for the Pro tier (monthly + annual). WEB_BASE_URL is derived from
# DOMAIN in compose.prod.yml, so it does not need to be set here.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=

# MCP server: comma-separated API keys accepted on the remote /mcp endpoint. REQUIRED in
# prod — if empty, auth is OFF and the publicly-routed /mcp would be an open firehose.
# Generate one with: openssl rand -hex 32
MCP_API_KEYS=
# Optional per-client rate limits for /mcp (token bucket; defaults shown).
# MCP_RATE_LIMIT_RPS=5
# MCP_RATE_LIMIT_BURST=20

# Image source. Defaults work for CD-pushed images; override to pin a tag.
REGISTRY=ghcr.io/joshskkim
IMAGE_TAG=latest
